# Cloudflare Tunnel
CLOUDFLARED_TOKEN=

# Restic
RESTIC_REPOSITORY=s3:s3.eu-central-003.backblazeb2.com/bucket-name/path
RESTIC_PASSWORD=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Backup paths
BACKUP_SOURCE=/srv/data
RESTIC_CACHE_DIR=/srv/data/restic-cache

# NocoBase
NOCOBASE_APP_KEY=example-app-key
NOCOBASE_DB_DATABASE=nocobase
NOCOBASE_DB_USER=nocobase
NOCOBASE_DB_PASSWORD=example-password

# Homarr
HOMARR_SECRET_ENCRYPTION_KEY=example-encryption-key