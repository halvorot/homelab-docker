# Domains
EXCALIDRAW_DOMAIN=excalidraw.example.com

# Upstreams on the shared Docker network
EXCALIDRAW_UPSTREAM=excalidraw:80

# Cloudflare Tunnel
CLOUDFLARED_TOKEN=

# Restic
RESTIC_REPOSITORY=s3:s3.eu-central-003.backblazeb2.com/bucket-name/path
RESTIC_PASSWORD=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Backup paths
BACKUP_SOURCE=/srv/data
RESTIC_CACHE_DIR=/srv/data/restic-cache
