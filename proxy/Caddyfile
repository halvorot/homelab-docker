http://dawarich.halvorteigen.no, http://timeline.halvorteigen.no {
	reverse_proxy http://dawarich_app:3000 {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-For {remote_host}
	}
}
