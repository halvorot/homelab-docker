http://ai.halvorteigen.no {
	@llama_api {
		path /api/*
		header Authorization "Bearer {$LLAMA_CPP_API_KEY}"
	}

	handle @llama_api {
		uri strip_prefix /api
		reverse_proxy llama-cpp:8080
	}

	handle {
		reverse_proxy open-webui:8080
	}
}

http://voiceboard.halvorteigen.no {
	handle /ws* {
		reverse_proxy voiceboard-server:8080
	}

	reverse_proxy voiceboard:80
}
