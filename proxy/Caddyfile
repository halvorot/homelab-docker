	reverse_proxy homepage:3000
}

http://dockhand.halvorteigen.no {
	reverse_proxy dockhand:3000
}

http://voiceboard.halvorteigen.no {
	handle /ws* {
		reverse_proxy voiceboard-server:8080
	}

	handle /health {
		reverse_proxy voiceboard-server:8080
	}

	reverse_proxy voiceboard:80
}

